DATABASE_URL=postgresql://username:password@localhost:5432/cloud_storage
TEST_DATABASE_URL=postgresql://username:password@localhost:5432/cloud_storage_test
JWT_SECRET_KEY=replace-with-a-long-random-secret
TEST_JWT_SECRET_KEY=replace-with-a-different-test-only-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
STORAGE_ROOT=storage
MAX_UPLOAD_SIZE_BYTES=104857600
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
REGISTRATION_OTP_SECRET_KEY=replace-with-a-different-long-random-secret
REGISTRATION_OTP_EXPIRE_MINUTES=10
REGISTRATION_OTP_MAX_ATTEMPTS=5
REGISTRATION_OTP_RESEND_COOLDOWN_SECONDS=60
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_STARTTLS=true
SMTP_TIMEOUT_SECONDS=10
