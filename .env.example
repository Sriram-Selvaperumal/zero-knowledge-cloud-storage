API_PREFIX=/api
DATABASE_URL=postgresql://username:password@localhost:5432/cloud_storage
TEST_DATABASE_URL=postgresql://username:password@localhost:5432/cloud_storage_test
JWT_SECRET_KEY=replace-with-a-long-random-secret
TEST_JWT_SECRET_KEY=replace-with-a-different-test-only-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_SECRET_KEY=replace-with-another-long-random-secret
REFRESH_TOKEN_EXPIRE_DAYS=30
REFRESH_TOKEN_REUSE_GRACE_SECONDS=10
REFRESH_COOKIE_NAME=prototype_refresh
REFRESH_COOKIE_SECURE=false
AUTH_THROTTLE_SECRET_KEY=replace-with-another-long-random-secret
LOGIN_MAX_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW_SECONDS=900
LOGIN_LOCKOUT_SECONDS=900
SHARE_MAX_ATTEMPTS=5
SHARE_ATTEMPT_WINDOW_SECONDS=900
SHARE_LOCKOUT_SECONDS=900
SHARE_DOWNLOAD_GRANT_EXPIRE_MINUTES=5
SHARE_MAX_EXPIRE_DAYS=365
STORAGE_ROOT=storage
MAX_UPLOAD_SIZE_BYTES=104857600
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
REGISTRATION_OTP_SECRET_KEY=replace-with-a-different-long-random-secret
REGISTRATION_OTP_EXPIRE_MINUTES=10
REGISTRATION_OTP_MAX_ATTEMPTS=5
REGISTRATION_OTP_RESEND_COOLDOWN_SECONDS=60
PASSWORD_RECOVERY_OTP_EXPIRE_MINUTES=10
PASSWORD_RECOVERY_GRANT_EXPIRE_MINUTES=10
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_AUTH=true
SMTP_STARTTLS=true
SMTP_TIMEOUT_SECONDS=10
